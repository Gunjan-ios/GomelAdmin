// GoMel Cars — PostgreSQL schema (migrated from MongoDB/Mongoose).
//
// Design notes:
//  - IDs stay app-generated strings (e.g. "user_ab12cd", "BK9F3A2C") so the
//    JSON contract the Flutter app depends on is unchanged. They are assigned
//    by a Prisma client extension (see src/db/prisma.js), NOT by the database.
//  - Embedded Mongo sub-documents become JSONB (`Json`) columns.
//  - Mongo scalar arrays become native Postgres arrays (`String[]`).
//  - Former Mongoose `ref`s are kept as plain indexed string columns rather
//    than enforced foreign keys — they were never enforced in Mongo (many
//    default to "" / null, and Booking embeds the whole car), so enforcing
//    them now would reject otherwise-valid writes.
//  - Former enum fields are plain strings holding the same values as before.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id
  name          String @default("")
  phone         String @unique
  email         String @default("")
  avatarUrl     String @default("")
  licenseStatus String @default("notSubmitted")
  walletBalance Float  @default(0)
  upiId         String @default("")

  referralCode String @default("")
  referredBy   String @default("")

  role String @default("user")

  // Embedded objects (were Mongo sub-docs): { planId, status, startedAt, expiresAt }.
  subscription Json?
  // { licenseNumber, frontImage, backImage }.
  kyc          Json?
  // Array of { token, platform, updatedAt }.
  deviceTokens Json  @default("[]")

  passwordHash String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referralCode])
}

model Car {
  id                 String   @id
  name               String
  type               String   @default("")
  images             String[] @default([])
  // RC (Registration Certificate) book photos — ownership proof. [front, back].
  rcBook             String[] @default([])
  pricePerHour       Float    @default(0)
  pricePerDay        Float    @default(0)
  rating             Float    @default(0)
  reviewCount        Int      @default(0)
  distanceKm         Float    @default(0)
  transmission       String   @default("manual")
  fuel               String   @default("petrol")
  seats              Int      @default(5)
  features           String[] @default([])
  pickupAddress      String   @default("")
  lat                Float    @default(0)
  lng                Float    @default(0)
  fuelPolicy         String   @default("")
  cancellationPolicy String   @default("")
  // { name, avatarUrl, rating, trips }.
  host               Json?

  ownerId String?
  active  Boolean @default(true)
  city    String  @default("Ahmedabad")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Booking {
  id               String   @id
  // The whole car JSON is embedded (matches Booking.toJson in the app).
  car              Json
  start            DateTime
  end              DateTime
  package          String   @default("daily")
  // { base, taxes, deposit, addOns, discount, rewardDiscount }.
  fare             Json?
  status           String   @default("upcoming")
  unlockOtp        String   @default("")
  tripStarted      Boolean  @default(false)
  isVerifiedByHost Boolean  @default(false)

  // Set once each time-based reminder has been pushed, so the every-minute
  // scheduler never sends a duplicate "trip starts/ends in 1 hour" notice.
  startReminderSent Boolean @default(false)
  endReminderSent   Boolean @default(false)

  user      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user])
}

model Payment {
  id       String @id
  user     String
  amount   Float
  currency String @default("INR")
  purpose  String @default("other")
  refId    String @default("")

  razorpayOrderId   String @default("")
  razorpayPaymentId String @default("")
  razorpaySignature String @default("")

  status String  @default("created")
  mock   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user])
  @@index([razorpayOrderId])
}

model DamageClaim {
  id             String   @id
  bookingId      String   @default("")
  carName        String   @default("")
  severity       String   @default("minor")
  description    String   @default("")
  photosCaptured Int      @default(0)
  photos         String[] @default([])
  status         String   @default("submitted")
  insurer        String   @default("")
  processingFee  Float    @default(0)

  user String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user])
}

model Conversation {
  id           String   @id
  type         String
  participants String[] @default([])
  title        String   @default("")
  carId        String   @default("")
  bookingId    String   @default("")
  lastMessage  String   @default("")
  lastAt       DateTime @default(now())
  // Map of userId -> last-read Date.
  reads        Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id           String   @id
  conversation String
  sender       String?
  senderRole   String   @default("user")
  text         String   @default("")
  images       String[] @default([])
  time         DateTime @default(now())

  @@index([conversation])
  @@index([time])
}

model Inspection {
  id             String   @id
  bookingId      String
  type           String
  fuelLevel      Float    @default(0)
  odometer       Float    @default(0)
  photosCaptured Int      @default(0)
  photos         String[] @default([])
  notes          String   @default("")
  at             DateTime @default(now())

  user String?

  @@index([bookingId])
  @@index([user])
}

model Loyalty {
  id      String @id
  user    String @unique
  points  Int    @default(0)
  // Array of { title, points, date }.
  history Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id    String   @id
  // null user => broadcast to everyone.
  user  String?
  type  String   @default("system")
  title String   @default("")
  body  String   @default("")
  date  DateTime @default(now())
  read  Boolean  @default(false)

  @@index([user])
}

model Otp {
  id             String   @id
  verificationId String
  phone          String
  code           String
  consumed       Boolean  @default(false)
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([verificationId])
  @@index([phone])
  @@index([expiresAt])
}

model Payout {
  id       String    @id
  host     String
  hostName String    @default("")
  amount   Float
  upiId    String    @default("")
  status   String    @default("requested")
  paidAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([host])
}

model PromoCode {
  id          String    @id
  code        String
  discountPct Float     @default(0)
  title       String    @default("")
  description String    @default("")
  maxDiscount Float     @default(0)
  minFare     Float     @default(0)
  active      Boolean   @default(true)
  validFrom   DateTime?
  validTo     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id          String    @id
  referrer    String
  referee     String    @unique
  code        String    @default("")
  reward      Float     @default(0)
  status      String    @default("pending")
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrer])
}

model Review {
  id        String   @id
  carId     String
  author    String   @default("")
  avatarUrl String   @default("")
  rating    Float    @default(0)
  comment   String   @default("")
  date      DateTime @default(now())

  @@index([carId])
}

model RewardCredit {
  id     String  @id
  user   String
  title  String  @default("")
  value  Float   @default(0)
  source String  @default("redeem")
  used   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user])
}

model Setting {
  id                 String  @id @default("app")
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String  @default("GoMel Cars is down for scheduled maintenance. Please check back soon.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id                String   @id
  name              String
  monthlyPrice      Float    @default(0)
  tagline           String   @default("")
  perks             String[] @default([])
  highlighted       Boolean  @default(false)
  discountPct       Float    @default(0)
  waiveDeposit      Boolean  @default(false)
  loyaltyMultiplier Float    @default(1)
}

model RedeemOption {
  id          String  @id
  title       String
  description String  @default("")
  cost        Int
  value       Float   @default(0)
  active      Boolean @default(true)
}

model WalletTransaction {
  id           String @id
  user         String
  type         String
  amount       Float
  source       String @default("topup")
  note         String @default("")
  balanceAfter Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user])
}
