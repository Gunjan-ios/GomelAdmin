{
  "name": "gomel-cars-backend",
  "version": "1.0.0",
  "description": "GoMel Cars REST API + Admin panel (Node + Express + PostgreSQL via Prisma)",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "predev": "lsof -ti :4000 | xargs kill 2>/dev/null || true",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed/seed.js",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio"
  },
  "prisma": {
    "seed": "node src/seed/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.5.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.19.3"
  }
}
